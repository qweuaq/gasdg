{
  "productName": "Am-Am VPN",
  "version": "2.0.0",
  "identifier": "com.amamvpn.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Am-Am VPN",
        "width": 520,
        "height": 800,
        "minWidth": 420,
        "minHeight": 600,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "displayLanguageSelector": true,
        "languages": ["Russian", "English"],
        "startMenuFolder": "Am-Am VPN"
      },
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    },
    "category": "Utility",
    "publisher": "Am-Am VPN",
    "shortDescription": "Modern VPN client powered by Xray-core",
    "longDescription": "Am-Am VPN is a modern desktop VPN client built with Tauri, React, and Rust. It supports VMess, VLESS, Trojan, and Shadowsocks protocols with subscription management, latency testing, and system proxy configuration.",
    "copyright": "© 2024-2026 Am-Am VPN"
  }
}
